# PromptRanks PoC - Environment Configuration
# Copy this file to .env and fill in your values

# === Deployment ===
# self_hosted: For organizations running their own instance
# saas: For the hosted promptranks.org platform
DEPLOYMENT_MODE=self_hosted
# Your instance domain (used for badge URLs, CORS, branding)
# Leave empty for localhost development
DEPLOYMENT_DOMAIN=

# === Content Registry (self-hosted only) ===
# License key for premium content packs (obtain from promptranks.org)
PROMPTRANKS_LICENSE_KEY=
CONTENT_REGISTRY_URL=https://content.promptranks.org
CONTENT_SYNC_INTERVAL=86400

# === LLM Provider (Required) ===
# Set the API key for your chosen provider. LiteLLM reads these from env:
#   OpenAI:    OPENAI_API_KEY=sk-xxx
#   Anthropic: ANTHROPIC_API_KEY=sk-ant-xxx
#   Azure:     AZURE_API_KEY=xxx + AZURE_API_BASE=https://xxx.openai.azure.com
#   Ollama:    No key needed (local)
# See: https://docs.litellm.ai/docs/providers
OPENAI_API_KEY=sk-your-key-here

# Model names use provider prefix: openai/gpt-4o, anthropic/claude-sonnet-4-6, ollama/llama3, etc.
LLM_EXECUTOR_MODEL=openai/gpt-4o
LLM_JUDGE_MODEL=openai/gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# === Database ===
POSTGRES_USER=promptranks
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=promptranks
DATABASE_URL=postgresql+asyncpg://promptranks:change-me-in-production@postgres:5432/promptranks

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === Frontend ===
VITE_API_URL=http://localhost:8000

# === Assessment ===
QUICK_ASSESSMENT_TIME_LIMIT=900
FULL_KBA_TIME_LIMIT=900
FULL_PPA_TIME_LIMIT=1800
